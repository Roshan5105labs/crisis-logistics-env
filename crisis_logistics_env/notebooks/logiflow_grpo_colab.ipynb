                                     "# === GRAPH 2: Training Loss Curve (from trainer_state.json) ===\n",
                                     "import json\n",
                                     "import math\n",
                                     "from pathlib import Path\n",
                                     "import pandas as pd\n",
                                     "import matplotlib.pyplot as plt\n",
                                     "from IPython.display import display, Image\n",
                                     "\n",
                                     "ARTIFACTS = Path(\u0027outputs/logiflow-grpo-script/artifacts\u0027)\n",
                                     "RUN_DIR = Path(\u0027outputs/logiflow-grpo-script\u0027)\n",
                                     "ARTIFACTS.mkdir(parents=True, exist_ok=True)\n",
                                     "\n",
                                     "def _latest_trainer_state(run_dir: Path) -\u003e Path | None:\n",
                                     "    direct = run_dir / \u0027trainer_state.json\u0027\n",
                                     "    if direct.exists():\n",
                                     "        return direct\n",
                                     "    ckpts = []\n",
                                     "    for p in run_dir.glob(\u0027checkpoint-*/trainer_state.json\u0027):\n",
                                     "        try:\n",
                                     "            step = int(p.parent.name.split(\u0027-\u0027)[-1])\n",
                                     "        except Exception:\n",
                                     "            step = -1\n",
                                     "        ckpts.append((step, p))\n",
                                     "    if not ckpts:\n",
                                     "        return None\n",
                                     "    ckpts.sort(key=lambda x: x[0])\n",
                                     "    return ckpts[-1][1]\n",
                                     "\n",
                                     "state_path = _latest_trainer_state(RUN_DIR)\n",
                                     "if state_path is None:\n",
                                     "    print(\u0027trainer_state.json not found. Run training cell first.\u0027)\n",
                                     "else:\n",
                                     "    state = json.loads(state_path.read_text(encoding=\u0027utf-8\u0027))\n",
                                     "    history = state.get(\u0027log_history\u0027, [])\n",
                                     "\n",
                                     "    rows = []\n",
                                     "    for r in history:\n",
                                     "        if not isinstance(r, dict):\n",
                                     "            continue\n",
                                     "        if \u0027loss\u0027 in r and isinstance(r[\u0027loss\u0027], (int, float)):\n",
                                     "            rows.append({\u0027step\u0027: r.get(\u0027step\u0027, len(rows) + 1), \u0027loss\u0027: float(r[\u0027loss\u0027])})\n",
                                     "        elif \u0027train_loss\u0027 in r and isinstance(r[\u0027train_loss\u0027], (int, float)):\n",
                                     "            rows.append({\u0027step\u0027: r.get(\u0027step\u0027, len(rows) + 1), \u0027loss\u0027: float(r[\u0027train_loss\u0027])})\n",
                                     "\n",
                                     "    if not rows:\n",
                                     "        print(\u0027No loss values found in trainer_state log_history.\u0027)\n",
                                     "    else:\n",
                                     "        df = pd.DataFrame(rows).dropna()\n",
                                     "        df = df.sort_values(\u0027step\u0027).drop_duplicates(\u0027step\u0027, keep=\u0027last\u0027)\n",
                                     "\n",
                                     "        max_abs = float(df[\u0027loss\u0027].abs().max()) if len(df) else 0.0\n",
                                     "        scale = 1.0 if max_abs \u003e= 1e-3 else 1e9\n",
