                                     "        ax.set_ylim(0, 1.15)\n",
                                     "        ax.set_ylabel(\u0027Score (0â€“1)\u0027, color=TEXT, fontsize=10)\n",
                                     "        ax.set_title(f\u0027Task: {task.upper()}\u0027, color=TEXT, fontsize=11,\n",
                                     "                     fontweight=\u0027bold\u0027)\n",
                                     "        ax.tick_params(colors=TEXT)\n",
